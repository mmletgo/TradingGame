      "fastapi",
      "uvicorn",
      "websockets",
      "neat-python",
      "numpy",
      "pydantic"
    ],
    "cython_modules": [
      "orderbook"
    ],
    "frontend": {
      "framework": "React + TypeScript",
      "charts": "ECharts",
      "build_tool": "Vite"
    }
  },
