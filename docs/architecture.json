          "name": "get_action_space",
          "signature": "def get_action_space(self) -> list[ActionType]",
          "description": "返回做市商的可用动作空间 [QUOTE, CLEAR_POSITION]",
          "returns": "list[ActionType]"
        },
        {
          "name": "decide",
          "signature": "def decide(self, orderbook: OrderBook, recent_trades: list[Trade]) -> tuple[ActionType, dict[str, Any]]",
          "description": "覆盖基类，做市商专用决策逻辑。神经网络输出 22 个值：动作选择(2) + 5买单(价格+数量权重) + 5卖单(价格+数量权重)。10 个订单的数量权重映射到 [0,1] 后归一化，确保总和为 1.0",
          "parameters": [
            {"name": "orderbook", "type": "OrderBook", "description": "订单簿对象"},
            {"name": "recent_trades", "type": "list[Trade]", "description": "最近成交记录"}
          ],
          "returns": "(ActionType, dict)"
        },
        {
          "name": "execute_action",
          "signature": "def execute_action(self, action: ActionType, params: dict[str, Any], event_bus: EventBus) -> None",
          "description": "执行 QUOTE 或 CLEAR_POSITION 动作",
          "parameters": [
            {"name": "action", "type": "ActionType", "description": "动作类型"},
            {"name": "params", "type": "dict", "description": "动作参数"},
            {"name": "event_bus", "type": "EventBus", "description": "事件总线"}
